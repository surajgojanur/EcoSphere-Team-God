# PostgreSQL
POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=ecosphere_dev_password
POSTGRES_DB=ecosphere
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://ecosphere:ecosphere_dev_password@db:5432/ecosphere
JWT_SECRET=replace-with-a-long-development-secret-at-least-32-bytes
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000
JSON_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
ENABLE_SCHEDULED_JOBS=false
SCORE_JOB_CRON=0 1 * * *
OVERDUE_JOB_CRON=0 2 * * *

# Frontend
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:4000
